# ─── Server-side only (never exposed to browser) ───
# Testnet wallet private key for server-side bridging
# Replace with your own key before deploying to mainnet
BRIDGE_PRIVATE_KEY=your_testnet_private_key_here

# ─── Optional ───
# Arc Testnet RPC (uses public endpoint by default)
NEXT_PUBLIC_ARC_TESTNET_RPC=https://rpc.arc.network/testnet
